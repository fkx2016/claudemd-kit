{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npx wrangler dev)",
      "Bash(npx wrangler tail *)",
      "Bash(npx wrangler deploy)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard origin/*)",
      "Bash(npx wrangler d1 execute * --remote *DROP*)",
      "Bash(npx wrangler secret delete *)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(~/.gnupg/*)",
      "Read(*.env)",
      "Read(*credentials*)",
      "Read(*.pem)",
      "Read(*.key)"
    ]
  }
}
