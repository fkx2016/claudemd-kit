{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npx wrangler dev)",
      "Bash(npx wrangler tail *)",
      "Bash(npx wrangler deploy)",
      "Bash(npx wrangler pages deploy *)",
      "Bash(npx wrangler r2 *)",
      "Bash(npx wrangler d1 *)",
      "Bash(bash scripts/*)",
      "Bash(zip -r *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git push origin *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(npx wrangler secret delete *)",
      "Bash(npx wrangler r2 bucket delete *)",
      "Bash(npx wrangler d1 delete *)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/*)",
      "Read(*.env)",
      "Read(.dev.vars)",
      "Read(*credentials*)"
    ]
  }
}
